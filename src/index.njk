---
layout: layouts/base.njk
pagination:
  data: collections.pagedArticles
  size: 1
  alias: paged
permalink: "/{{ paged.lang }}/{% if paged.pageNumber > 0 %}trang-{{ paged.pageNumber + 1 }}/{% endif %}index.html"
eleventyComputed:
  lang: "{{ paged.lang }}"
  title: "{{ 'Trang chủ' if paged.lang == 'vi' else 'Home' }} - {{ paged.pageNumber + 1 }}"
  description: "{{ 'Danh sách bài viết mới nhất về công nghệ AiOps' if paged.lang == 'vi' else 'Latest articles about AiOps technology' }}"
---

<style>
  .hero {
    text-align: center;
    padding: 64px 0;
    background: linear-gradient(to bottom, #f0f7ff, #ffffff);
    border-radius: 24px;
    margin-bottom: 48px;
  }

  .hero h1 {
    font-size: 3.5rem;
    margin-bottom: 1rem;
    background: linear-gradient(to right, #2563eb, #7c3aed);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero p {
    font-size: 1.25rem;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 32px;
    margin-top: 32px;
  }

  .card {
    background: white;
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .card:hover {
    transform: translateY(-8px);
    border-color: var(--primary);
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
  }

  .card-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
    background: #f3f4f6;
  }

  .card-content {
    padding: 24px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .card-tag {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--primary);
    margin-bottom: 12px;
    letter-spacing: 0.05em;
  }

  .card-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-main);
    margin: 0 0 12px 0;
    line-height: 1.4;
  }

  .card-excerpt {
    font-size: 0.9375rem;
    color: var(--text-muted);
    margin-bottom: 20px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    margin-top: auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.8125rem;
    color: var(--text-muted);
  }

  .read-more {
    color: var(--primary);
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  /* Pagination styles */
  .pagination-nav {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: 64px;
  }

  .pagination-link {
    padding: 8px 16px;
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    color: var(--text-main);
    font-weight: 600;
    transition: all 0.2s;
  }

  .pagination-link:hover:not(.disabled) {
    border-color: var(--primary);
    color: var(--primary);
    background: var(--bg-alt);
  }

  .pagination-link.active {
    background: var(--primary);
    color: white;
    border-color: var(--primary);
  }

  .pagination-link.disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  @media (max-width: 640px) {
    .hero h1 { font-size: 2.5rem; }
    .grid { grid-template-columns: 1fr; }
  }
</style>

{% if paged.pageNumber == 0 %}
<div class="hero">
  <h1>{{ 'Cầu nối AiOps' if paged.lang == 'vi' else 'AiOps Bridge' }}</h1>
  <p>{{ 'Kiến thức chuyên sâu và giải pháp tối ưu cho vận hành hệ thống thông minh.' if paged.lang == 'vi' else 'In-depth knowledge and optimal solutions for smart system operations.' }}</p>
</div>
{% endif %}

<section>
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
    <h2 style="margin: 0;">{{ 'Bài viết mới nhất' if paged.lang == 'vi' else 'Latest Articles' }}</h2>
    <span style="color: var(--text-muted); font-size: 0.875rem;">{{ paged.items.length }} {{ 'bài viết trên trang này' if paged.lang == 'vi' else 'articles on this page' }}</span>
  </div>

  <div class="grid">
    {% for item in paged.items %}
      <a href="{{ item.url }}" class="card">
        <img src="{{ item.data.image or 'https://images.unsplash.com/photo-1635070041078-e363dbe005cb?auto=format&fit=crop&w=800&q=80' }}" 
             alt="{{ item.data.title }}" 
             class="card-image" 
             loading="lazy"
             onerror="this.src='https://images.unsplash.com/photo-1635070041078-e363dbe005cb?auto=format&fit=crop&w=800&q=80';">
        <div class="card-content">
          <div class="card-tag">{{ item.data.category or 'AiOps' }}</div>
          <h3 class="card-title">{{ item.data.title or item.fileSlug }}</h3>
          <p class="card-excerpt">{{ item.data.description }}</p>
          <div class="card-footer">
            <span>{{ item.date | date("yyyy-MM-dd") }}</span>
            <span class="read-more">
              {{ 'Xem thêm' if paged.lang == 'vi' else 'Read more' }}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </div>
        </div>
      </a>
    {% endfor %}
  </div>

  {# Pagination Nav #}
  {% if paged.totalPages > 1 %}
  <nav class="pagination-nav">
    {% if paged.pageNumber > 0 %}
      <a href="/{{ paged.lang }}/{% if paged.pageNumber > 1 %}trang-{{ paged.pageNumber }}/{% endif %}index.html" class="pagination-link">
        &larr; {{ 'Trước' if paged.lang == 'vi' else 'Prev' }}
      </a>
    {% endif %}

    {% for i in range(0, paged.totalPages) %}
      <a href="/{{ paged.lang }}/{% if i > 0 %}trang-{{ i + 1 }}/{% endif %}index.html" class="pagination-link {{ 'active' if i == paged.pageNumber }}">
        {{ i + 1 }}
      </a>
    {% endfor %}

    {% if paged.pageNumber < paged.totalPages - 1 %}
      <a href="/{{ paged.lang }}/trang-{{ paged.pageNumber + 2 }}/index.html" class="pagination-link">
        {{ 'Sau' if paged.lang == 'vi' else 'Next' }} &rarr;
      </a>
    {% endif %}
  </nav>
  {% endif %}
</section>
